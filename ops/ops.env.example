# Copy to ops.env and fill in. NEVER commit the real file.

# --- Claude auth (pick ONE) ---
# Option A: API key (pay-per-use, separate from a Claude subscription):
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Option B: leave the key empty and `claude login` on the box once as the 'ops'
# user so ~/.claude holds the session. The runner accepts either.

# --- Claude CLI ---
CLAUDE_BIN=claude
# Full-auto (no human approval). Confirm the exact flag with `claude --help`
# for your version; common values: "--permission-mode bypassPermissions"
# or "--dangerously-skip-permissions".
CLAUDE_ARGS=--permission-mode acceptEdits

# --- Where the agents operate (clone the product + support repos under here) ---
OPS_WORKDIR=/opt/lumina
# Path to the uptime monitor's state file (for the ops/monitor agent):
OPS_UPTIME_STATE=/opt/linus-watchtower/watchtower/uptime_monitor/uptime_state.json

# --- Morning briefing SMS (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1XXXXXXXXXX
BRIEFING_TO=+1XXXXXXXXXX
